DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dashboard

# Schema: ordered SQL files live in postgres/migrations/. Apply after DATABASE_URL is set:
#   npm run db:apply-migrations

# NextAuth (Auth.js) — required for sign-in. Generate: openssl rand -base64 32
AUTH_SECRET=change-this-to-a-long-random-secret
# Dev app URL (must match the origin you open in the browser)
NEXTAUTH_URL=http://localhost:3000

# Legacy alias still read by some tooling if AUTH_SECRET is unset:
JWT_SECRET=change-this-to-a-long-random-secret

# Optional: set false for local Postgres without SSL
# PGSSL=false

# Required only when copying existing production data
SOURCE_DATABASE_URL=postgresql://postgres:password@source-host:5432/postgres

