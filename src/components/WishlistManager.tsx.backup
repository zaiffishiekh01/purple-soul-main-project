import { useState, useEffect } from 'react';
import { Heart, ShoppingCart, Trash2, TrendingDown, Bell, BellOff, Share2, Star, DollarSign, Package, AlertCircle, Sparkles, Eye, Plus, Filter, Grid, List, Tag, Calendar, Target, X, Clock } from 'lucide-react';
import { supabase } from '../lib/supabase';

interface WishlistManagerProps {
  onAddToCart?: (productId: string, quantity: number) => void;
  onViewProduct?: (productId: string) => void;
}

export default function WishlistManager({ onAddToCart, onViewProduct }: WishlistManagerProps) {
  const [wishlists, setWishlists] = useState<any[]>([]);
  const [selectedWishlist, setSelectedWishlist] = useState<any | null>(null);
  const [wishlistItems, setWishlistItems] = useState<any[]>([]);
  const [loading, setLoading] = useState(true);
  const [viewMode, setViewMode] = useState<'grid' | 'list'>('grid');
  const [sortBy, setSortBy] = useState<'date' | 'price' | 'priority'>('date');
  const [filterPriority, setFilterPriority] = useState<string>('all');
  const [showCreateModal, setShowCreateModal] = useState(false);
  const [showShareModal, setShowShareModal] = useState(false);
  const [newWishlistName, setNewWishlistName] = useState('');
  const [newWishlistOccasion, setNewWishlistOccasion] = useState('');
  const [newWishlistBudget, setNewWishlistBudget] = useState('');

  useEffect(() => {
    loadWishlists();
  }, []);

  useEffect(() => {
    if (selectedWishlist) {
      loadWishlistItems(selectedWishlist);
    }
  }, [selectedWishlist]);

  async function loadWishlists() {
    const { data: { user } } = await supabase.auth.getUser();
    if (!user) return;

    const { data } = await supabase
      .from('wishlists')
      .select('*')
      .eq('user_id', user.id)
      .order('created_at', { ascending: false });

    if (data) {
      setWishlists(data);
      if (data.length > 0 && !selectedWishlist) {
        setSelectedWishlist(data[0].id);
      }
    }
  }

  async function loadWishlistItems(wishlistId: string) {
    const { data } = await supabase
      .from('wishlist_items')
      .select('*')
      .eq('wishlist_id', wishlistId)
      .order('added_at', { ascending: false });

    if (data) setWishlistItems(data);
  }

  async function createWishlist() {
    const { data: { user } } = await supabase.auth.getUser();
    if (!user) {
      alert('Please sign in to create a wishlist');
      return;
    }

    const { data, error } = await supabase
      .from('wishlists')
      .insert({
        ...newWishlist,
        user_id: user.id,
        event_date: newWishlist.event_date || null
      })
      .select()
      .single();

    if (!error && data) {
      setWishlists([data, ...wishlists]);
      setSelectedWishlist(data.id);
      setShowCreateForm(false);
      setNewWishlist({
        name: '',
        description: '',
        is_public: false,
        is_registry: false,
        event_date: ''
      });
    }
  }

  async function deleteWishlist(id: string) {
    if (!confirm('Are you sure you want to delete this wishlist?')) return;

    const { error } = await supabase.from('wishlists').delete().eq('id', id);

    if (!error) {
      setWishlists(wishlists.filter(w => w.id !== id));
      if (selectedWishlist === id) {
        setSelectedWishlist(wishlists[0]?.id || null);
      }
    }
  }

  async function removeItem(itemId: string) {
    const { error } = await supabase.from('wishlist_items').delete().eq('id', itemId);

    if (!error) {
      setWishlistItems(wishlistItems.filter(i => i.id !== itemId));
    }
  }

  async function updateItemPriority(itemId: string, priority: 'high' | 'medium' | 'low') {
    const { error } = await supabase
      .from('wishlist_items')
      .update({ priority })
      .eq('id', itemId);

    if (!error) {
      setWishlistItems(wishlistItems.map(item =>
        item.id === itemId ? { ...item, priority } : item
      ));
    }
  }

  function copyShareLink() {
    const wishlist = wishlists.find(w => w.id === selectedWishlist);
    if (!wishlist) return;

    const shareUrl = `${window.location.origin}/wishlist/${wishlist.share_code}`;
    navigator.clipboard.writeText(shareUrl);
    setCopiedCode(true);
    setTimeout(() => setCopiedCode(false), 2000);
  }

  const currentWishlist = wishlists.find(w => w.id === selectedWishlist);

  return (
    <div className="max-w-7xl mx-auto p-6">
      <div className="mb-8">
        <h1 className="text-3xl font-bold text-primary mb-2">My Wishlists & Registries</h1>
        <p className="text-secondary">Save items you love and share with family and friends</p>
      </div>

      <div className="grid lg:grid-cols-4 gap-6">
        {/* Sidebar */}
        <div className="lg:col-span-1">
          <button
            onClick={() => setShowCreateForm(true)}
            className="w-full bg-amber-600 text-white px-4 py-3 rounded-lg hover:bg-amber-700 font-medium flex items-center justify-center gap-2 mb-4"
          >
            <Plus className="w-5 h-5" />
            Create New
          </button>

          <div className="space-y-2">
            {wishlists.map((wishlist) => (
              <button
                key={wishlist.id}
                onClick={() => setSelectedWishlist(wishlist.id)}
                className={`w-full text-left p-4 rounded-lg border-2 transition-all ${
                  selectedWishlist === wishlist.id
                    ? 'border-amber-600 bg-amber-50'
                    : 'border-default hover:border-default'
                }`}
              >
                <div className="flex items-start justify-between mb-2">
                  <div className="flex items-center gap-2">
                    {wishlist.is_registry ? (
                      <Gift className="w-5 h-5 text-amber-600" />
                    ) : (
                      <Heart className="w-5 h-5 text-pink-500" />
                    )}
                    <span className="font-semibold">{wishlist.name}</span>
                  </div>
                  {wishlist.is_public && (
                    <Share2 className="w-4 h-4 text-purple-600" />
                  )}
                </div>
                {wishlist.event_date && (
                  <div className="flex items-center gap-2 text-sm text-secondary">
                    <Calendar className="w-4 h-4" />
                    {new Date(wishlist.event_date).toLocaleDateString()}
                  </div>
                )}
              </button>
            ))}
          </div>
        </div>

        {/* Main Content */}
        <div className="lg:col-span-3">
          {showCreateForm && (
            <div className="bg-surface p-6 rounded-lg border-2 border-amber-200 mb-6">
              <h2 className="text-xl font-bold mb-4">Create New Wishlist</h2>

              <div className="space-y-4">
                <div>
                  <label className="block text-sm font-medium text-secondary mb-2">
                    Name *
                  </label>
                  <input
                    type="text"
                    value={newWishlist.name}
                    onChange={(e) => setNewWishlist({ ...newWishlist, name: e.target.value })}
                    placeholder="e.g., Wedding Registry, Housewarming Wishes"
                    className="w-full p-3 border rounded-lg"
                  />
                </div>

                <div>
                  <label className="block text-sm font-medium text-secondary mb-2">
                    Description
                  </label>
                  <textarea
                    value={newWishlist.description}
                    onChange={(e) => setNewWishlist({ ...newWishlist, description: e.target.value })}
                    placeholder="Tell others what this wishlist is for..."
                    className="w-full p-3 border rounded-lg"
                    rows={3}
                  />
                </div>

                <div className="grid md:grid-cols-2 gap-4">
                  <div className="flex items-center gap-3 p-4 border rounded-lg">
                    <input
                      type="checkbox"
                      id="is_public"
                      checked={newWishlist.is_public}
                      onChange={(e) => setNewWishlist({ ...newWishlist, is_public: e.target.checked })}
                      className="w-4 h-4"
                    />
                    <label htmlFor="is_public" className="text-sm font-medium cursor-pointer">
                      Make Public (Shareable)
                    </label>
                  </div>

                  <div className="flex items-center gap-3 p-4 border rounded-lg">
                    <input
                      type="checkbox"
                      id="is_registry"
                      checked={newWishlist.is_registry}
                      onChange={(e) => setNewWishlist({ ...newWishlist, is_registry: e.target.checked })}
                      className="w-4 h-4"
                    />
                    <label htmlFor="is_registry" className="text-sm font-medium cursor-pointer">
                      Gift Registry
                    </label>
                  </div>
                </div>

                {newWishlist.is_registry && (
                  <div>
                    <label className="block text-sm font-medium text-secondary mb-2">
                      Event Date
                    </label>
                    <input
                      type="date"
                      value={newWishlist.event_date}
                      onChange={(e) => setNewWishlist({ ...newWishlist, event_date: e.target.value })}
                      className="w-full p-3 border rounded-lg"
                    />
                  </div>
                )}

                <div className="flex gap-3">
                  <button
                    onClick={createWishlist}
                    className="flex-1 bg-amber-600 text-white py-3 rounded-lg hover:bg-amber-700 font-medium"
                  >
                    Create Wishlist
                  </button>
                  <button
                    onClick={() => setShowCreateForm(false)}
                    className="px-6 py-3 border border-default rounded-lg hover:bg-surface-deep"
                  >
                    Cancel
                  </button>
                </div>
              </div>
            </div>
          )}

          {currentWishlist && (
            <div>
              <div className="bg-surface p-6 rounded-lg border mb-6">
                <div className="flex items-start justify-between mb-4">
                  <div>
                    <h2 className="text-2xl font-bold text-primary mb-2">{currentWishlist.name}</h2>
                    {currentWishlist.description && (
                      <p className="text-secondary">{currentWishlist.description}</p>
                    )}
                  </div>
                  <button
                    onClick={() => deleteWishlist(currentWishlist.id)}
                    className="text-red-600 hover:text-red-700 p-2"
                  >
                    <Trash2 className="w-5 h-5" />
                  </button>
                </div>

                {currentWishlist.is_public && (
                  <div className="bg-purple-50 p-4 rounded-lg">
                    <div className="flex items-center justify-between">
                      <div>
                        <p className="text-sm font-medium text-purple-900 mb-1">Share this wishlist</p>
                        <code className="text-sm text-purple-700">
                          {window.location.origin}/wishlist/{currentWishlist.share_code}
                        </code>
                      </div>
                      <button
                        onClick={copyShareLink}
                        className="flex items-center gap-2 bg-purple-600 text-white px-4 py-2 rounded-lg hover:bg-purple-700"
                      >
                        {copiedCode ? (
                          <>
                            <Check className="w-4 h-4" />
                            Copied!
                          </>
                        ) : (
                          <>
                            <Copy className="w-4 h-4" />
                            Copy Link
                          </>
                        )}
                      </button>
                    </div>
                  </div>
                )}
              </div>

              {/* Wishlist Items */}
              <div className="grid gap-4">
                {wishlistItems.length === 0 ? (
                  <div className="text-center py-16 bg-surface-deep rounded-lg">
                    <Heart className="w-16 h-16 text-muted mx-auto mb-4" />
                    <p className="text-secondary mb-2">Your wishlist is empty</p>
                    <p className="text-sm text-muted">
                      Browse products and click the heart icon to add them here
                    </p>
                  </div>
                ) : (
                  wishlistItems.map((item) => (
                    <div
                      key={item.id}
                      className="bg-surface p-4 rounded-lg border hover:shadow-theme-md transition-shadow"
                    >
                      <div className="flex items-center justify-between">
                        <div className="flex-1">
                          <div className="flex items-center gap-4 mb-2">
                            <span className="font-semibold text-primary">Product ID: {item.product_id}</span>
                            <select
                              value={item.priority}
                              onChange={(e) => updateItemPriority(item.id, e.target.value as any)}
                              className={`px-3 py-1 rounded-full text-sm font-medium ${
                                item.priority === 'high'
                                  ? 'bg-red-100 text-red-800'
                                  : item.priority === 'medium'
                                  ? 'bg-yellow-100 text-yellow-800'
                                  : 'bg-surface-deep text-primary'
                              }`}
                            >
                              <option value="high">High Priority</option>
                              <option value="medium">Medium Priority</option>
                              <option value="low">Low Priority</option>
                            </select>
                          </div>

                          {item.notes && (
                            <p className="text-sm text-secondary mb-2">{item.notes}</p>
                          )}

                          <div className="text-sm text-muted">
                            Desired: {item.quantity_desired} | Purchased: {item.quantity_purchased}
                          </div>
                        </div>

                        <button
                          onClick={() => removeItem(item.id)}
                          className="text-red-600 hover:text-red-700 p-2"
                        >
                          <Trash2 className="w-5 h-5" />
                        </button>
                      </div>
                    </div>
                  ))
                )}
              </div>
            </div>
          )}

          {!currentWishlist && wishlists.length === 0 && !showCreateForm && (
            <div className="text-center py-16">
              <Heart className="w-20 h-20 text-muted mx-auto mb-4" />
              <h3 className="text-xl font-semibold text-primary mb-2">No wishlists yet</h3>
              <p className="text-secondary mb-6">Create your first wishlist to start saving items you love</p>
              <button
                onClick={() => setShowCreateForm(true)}
                className="bg-amber-600 text-white px-6 py-3 rounded-lg hover:bg-amber-700 font-medium inline-flex items-center gap-2"
              >
                <Plus className="w-5 h-5" />
                Create Your First Wishlist
              </button>
            </div>
          )}
        </div>
      </div>
    </div>
  );
}
